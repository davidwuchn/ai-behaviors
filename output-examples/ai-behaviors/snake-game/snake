#!/usr/bin/env bash
set -e

DIR="$(cd "$(dirname "$0")" && pwd)"
VENV="$DIR/.venv"

if ! "$VENV/bin/python" -c "import pygame" 2>/dev/null; then
    echo "Setting up environment..."
    python3 -m venv "$VENV"
    "$VENV/bin/pip" install --quiet pygame
fi

(
    source "$VENV/bin/activate"
    python "$DIR/main.py"
)
